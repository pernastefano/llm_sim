# ── LLM Simulation Demo — configuration template ─────────────────────────────
# Copy this file to config/.env and fill in your values:
#
#   cp config/.env.example config/.env
#
# config/.env is loaded automatically by the server (python-dotenv) and by
# docker-compose (env_file:).  Never commit config/.env to version control.

# ── Container user/group IDs ──────────────────────────────────────────────────
# Match these to your host user so bind-mounted files have the right ownership.
# Run `id -u` and `id -g` on your host to find the correct values.
PUID=1000
PGID=1000

# ── Application secret key ────────────────────────────────────────────────────
# REQUIRED in production — all Gunicorn workers must share the same key so
# that session cookies signed by worker A are accepted by worker B.
#
# Generate a secure key with:
#   python3 -c 'import secrets; print(secrets.token_hex(32))'
#
SECRET_KEY=change-me-in-production

# ── Cookie security ───────────────────────────────────────────────────────────
# Set to "true" when the app is served over HTTPS (recommended in production).
# Leave as "false" for local HTTP development.
SESSION_COOKIE_SECURE=false
